# API
ADMIN_API_KEY=dev-admin-key
ADMIN_AUTH_REQUIRED=true
REQUIRE_ORG_CONTEXT=false
CORS_ORIGINS=*

# Milvus (host / docker)
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=rag_chunks

# Light embeddings: TEI multilingual-e5-small (384-d)
EMBEDDER_URL=http://localhost:8080
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSION=384
EMBEDDING_MODEL_VERSION=e5-small-v1

# Optional reranker (empty = off)
RERANKER_URL=
RERANKING_MODEL=BAAI/bge-reranker-base

# Chunking / contextual (mock keeps ingest light)
CHUNK_MAX_TOKENS=512
CONTEXTUAL_RETRIEVAL_ENABLED=false
CONTEXTUAL_RETRIEVAL_MOCK=true

# LLM for /v1/ask
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini
# LLM_GATEWAY_URL=http://host:8080/v1/chat/completions

GUARDRAILS_ENABLED=true
GUARDRAILS_CHECK_PII=false
